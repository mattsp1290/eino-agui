{
  "unit": "convert",
  "name": "vision-gated-message-conversion",
  "source": {
    "repository": "github.com/mattsp1290/ag-ui-go-server-example",
    "commit": "a6dd6fd896ead9a06014a8a4bed0bb6a1a6cdfb5",
    "files": [
      "internal/agent/convert.go"
    ]
  },
  "cases": [
    {
      "name": "openai provider preserves text and image input parts",
      "input": {
        "provider": "openai",
        "aguiMessage": {
          "role": "user",
          "content": [
            {"type": "text", "text": "What is in this image?"},
            {
              "type": "image",
              "source": {
                "type": "url",
                "value": "https://example.test/cat.png"
              }
            }
          ]
        }
      },
      "normalized": {
        "einoRole": "user",
        "content": "",
        "userInputMultiContent": [
          {"type": "text", "text": "What is in this image?"},
          {
            "type": "image_url",
            "image": {
              "url": "https://example.test/cat.png"
            }
          }
        ]
      }
    },
    {
      "name": "non-vision provider drops image and joins text fragments",
      "input": {
        "provider": "openai-codex",
        "aguiMessage": {
          "role": "user",
          "content": [
            {"type": "text", "text": "First line"},
            {
              "type": "image",
              "source": {
                "type": "url",
                "value": "https://example.test/cat.png"
              }
            },
            {"type": "text", "text": "Second line"}
          ]
        }
      },
      "normalized": {
        "einoRole": "user",
        "content": "First line\nSecond line",
        "userInputMultiContent": null
      }
    }
  ],
  "messageTextCases": [
    {
      "name": "joins text fragments and drops image fragments",
      "input": {
        "role": "user",
        "content": [
          {"type": "text", "text": "First"},
          {"type": "image", "url": "https://example.test/cat.png"},
          {"type": "text", "text": "Second"}
        ]
      },
      "normalized": "First\nSecond"
    }
  ],
  "imagePartCases": [
    {
      "name": "structured URL source",
      "input": {
        "type": "image",
        "source": {
          "type": "url",
          "value": "https://example.test/cat.png"
        }
      },
      "normalized": {
        "type": "image_url",
        "image": {
          "url": "https://example.test/cat.png"
        }
      }
    },
    {
      "name": "structured data source",
      "input": {
        "type": "image",
        "source": {
          "type": "data",
          "value": "base64",
          "mimeType": "image/png"
        }
      },
      "normalized": {
        "type": "image_url",
        "image": {
          "base64Data": "base64",
          "mimeType": "image/png"
        }
      }
    },
    {
      "name": "legacy URL field",
      "input": {
        "type": "image",
        "url": "https://example.test/legacy.png"
      },
      "normalized": {
        "type": "image_url",
        "image": {
          "url": "https://example.test/legacy.png"
        }
      }
    },
    {
      "name": "legacy data field",
      "input": {
        "type": "image",
        "data": "legacy-base64",
        "mimeType": "image/jpeg"
      },
      "normalized": {
        "type": "image_url",
        "image": {
          "base64Data": "legacy-base64",
          "mimeType": "image/jpeg"
        }
      }
    }
  ],
  "toolCalls": {
    "agui": [
      {
        "id": "call-read",
        "type": "function",
        "function": {
          "name": "file_read",
          "arguments": "{\"path\":\"README.md\"}"
        }
      }
    ],
    "eino": [
      {
        "id": "call-write",
        "type": "function",
        "function": {
          "name": "file_write",
          "arguments": "{\"path\":\"README.md\",\"content\":\"ok\"}"
        }
      }
    ]
  },
  "aguiMessages": {
    "input": [
      {
        "einoRole": "system",
        "content": "system"
      },
      {
        "einoRole": "user",
        "content": "user"
      },
      {
        "einoRole": "assistant",
        "content": "assistant",
        "toolCalls": [
          {
            "id": "call-read",
            "type": "function",
            "function": {
              "name": "file_read",
              "arguments": "{\"path\":\"README.md\"}"
            }
          }
        ]
      },
      {
        "einoRole": "tool",
        "content": "result",
        "toolCallId": "call-read"
      }
    ],
    "normalized": [
      {
        "id": "<message-id>",
        "role": "system",
        "content": "system"
      },
      {
        "id": "<message-id>",
        "role": "user",
        "content": "user"
      },
      {
        "id": "<message-id>",
        "role": "assistant",
        "content": "assistant",
        "toolCalls": [
          {
            "id": "call-read",
            "type": "function",
            "function": {
              "name": "file_read",
              "arguments": "{\"path\":\"README.md\"}"
            }
          }
        ]
      },
      {
        "id": "<message-id>",
        "role": "tool",
        "content": "result",
        "toolCallId": "call-read"
      }
    ]
  }
}
